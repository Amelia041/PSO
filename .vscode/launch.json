{
  "project": "StudentSync",
  "pipeline": [
    {
      "stage": "Source Control",
      "tool": "GitHub",
      "trigger": "Push to main"
    },
    {
      "stage": "Testing",
      "tool": "Go Test",
      "command": "go test ./..."
    },
    {
      "stage": "Build",
      "tool": "Go Compiler",
      "command": "go build -o studentsync"
    },
    {
      "stage": "Containerization",
      "tool": "Docker",
      "command": "docker build"
    },
    {
      "stage": "Registry",
      "tool": "Docker Hub",
      "command": "docker push"
    },
    {
      "stage": "Deployment",
      "tool": "Azure App Service",
      "status": "Production"
    }
  ]
}